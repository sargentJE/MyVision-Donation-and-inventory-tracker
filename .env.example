# =============================================================================
# MyVision Equipment Tracker — Environment Variables
# Copy to .env and fill in values before running.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://myvision:myvision@localhost:5432/equipment_tracker
POSTGRES_USER=myvision
POSTGRES_PASSWORD=myvision
POSTGRES_DB=equipment_tracker

# --- Auth ---
JWT_SECRET=                     # min 32 chars — change in production
JWT_EXPIRY=60m
REFRESH_TOKEN_SECRET=           # different from JWT_SECRET — change in production
REFRESH_TOKEN_EXPIRY=7d

# --- Admin Bootstrap Seed ---
SEED_ADMIN_NAME=Dev Admin
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_PASSWORD=admin123    # change immediately after first login

# --- App ---
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
WEB_ORIGIN=http://localhost:3000

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=300

# --- Notification Cron ---
CRON_SCHEDULE=0 6 * * *         # 06:00 UTC daily — configurable cron expression
