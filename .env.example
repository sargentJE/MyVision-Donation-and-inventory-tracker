# =============================================================================
# MyVision Equipment Tracker — Environment Variables
# Copy to .env and fill in values before running.
# =============================================================================

# --- Database ---
# Dev: localhost. Production: overridden by docker-compose.prod.yml to use 'db' service name.
DATABASE_URL=postgresql://myvision:myvision@localhost:5432/equipment_tracker
POSTGRES_USER=myvision
POSTGRES_PASSWORD=myvision
POSTGRES_DB=equipment_tracker

# --- Auth ---
# PRODUCTION: generate both with `openssl rand -hex 32`
JWT_SECRET=                     # min 32 chars
JWT_EXPIRY=60m
REFRESH_TOKEN_SECRET=           # different from JWT_SECRET
REFRESH_TOKEN_EXPIRY=7d

# --- Admin Bootstrap Seed ---
# Seed creates this account on first deploy. Change password immediately via Settings.
SEED_ADMIN_NAME=Dev Admin
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_PASSWORD=admin123

# --- App ---
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
WEB_ORIGIN=http://localhost:3000
# Production: WEB_ORIGIN=https://equipment.sightkick.co.uk

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=300

# --- Notification Cron ---
CRON_SCHEDULE=0 6 * * *         # 06:00 UTC daily
